---
import BaseLayout from "../layouts/BaseLayout.astro";
import Divider from "../components/Divider.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import { socialLinks } from "../data/socials";
import { site } from "../data/site";

const description = site.description;
---

<BaseLayout title="varnish" description={description}>
  <h1 class="name">varnish</h1>
  <p class="intro-meta">
    <span>21 y/o</span>
    <span aria-hidden="true">·</span>
    <span>software engineering student</span>
    <span aria-hidden="true">·</span>
    <span>tampere, finland</span>
  </p>
  <p class="intro-text">
    hi, i'm varnish. i'm doing my bachelors in software engineering at tampere university of applied sciences.
    i love solving problems and building things around random ideas, annoyances, or rabbit holes i fall into.
    i'm also interested in finance. outside of coding, i'm probably watching formula 1, reading a book, watching some show
    or playing flight sim.
  </p>

  <Divider />
  <ProjectsSection />

  <Divider />
  <section class="socials" aria-labelledby="socials-title">
    <h2 id="socials-title" class="socials__title">
      <span class="socials__mark" aria-hidden="true">*</span> find me here
    </h2>
    <ul class="socials__list">
      {
        socialLinks.map(({ href, label }) => (
          <li>
            <a href={href} target="_blank" rel="noopener noreferrer">
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
